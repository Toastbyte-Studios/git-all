# Required for GitHub contributions (GraphQL API needs a token even for public data)
GITHUB_TOKEN=ghp_your_token_here

# Session encryption secret (32+ random bytes recommended)
SESSION_SECRET=long_random_string_here

# Optional OAuth providers (lets signed-in users verify account ownership)
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

GITLAB_CLIENT_ID=your_gitlab_application_client_id
GITLAB_CLIENT_SECRET=your_gitlab_application_client_secret

BITBUCKET_CLIENT_KEY=your_bitbucket_oauth_consumer_key
BITBUCKET_CLIENT_SECRET=your_bitbucket_oauth_consumer_secret

# Optional analytics foundation
# Cloudflare Web Analytics token (Phase A cookieless baseline)
NEXT_PUBLIC_CF_WEB_ANALYTICS_TOKEN=your_cloudflare_web_analytics_token
# GA4 Measurement Protocol credentials for server-side events (Phase B)
ANALYTICS_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
ANALYTICS_GA4_API_SECRET=your_ga4_measurement_protocol_api_secret
# Set to 1 to require consent before client-side analytics events are sent
NEXT_PUBLIC_ANALYTICS_REQUIRE_CONSENT=0

# ── Cloudflare D1 (persistent profiles) ─────────────────────────────
# D1 is only available when running via `wrangler dev` (npm run cf:preview)
# or in a deployed Worker.  Plain `next dev` runs without it — reads/writes
# are skipped and a warning is logged instead.
#
# Setup:
#   1. wrangler d1 create gitall
#   2. Copy the database_id into wrangler.jsonc → d1_databases[0].database_id
#   3. wrangler d1 migrations apply gitall          # production
#   4. wrangler d1 migrations apply gitall --local  # local (cf:preview)

