# Cloudflare Workers local dev secrets (copy to .dev.vars and fill in values)
# See https://developers.cloudflare.com/workers/configuration/secrets/

# Required for GitHub contributions API (GraphQL API needs a token even for public data)
GITHUB_TOKEN=ghp_your_token_here

# Session encryption secret (32+ random bytes recommended)
SESSION_SECRET=long_random_string_here

# Optional OAuth providers for verified account connections
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret

GITLAB_CLIENT_ID=your_gitlab_application_client_id
GITLAB_CLIENT_SECRET=your_gitlab_application_client_secret

BITBUCKET_CLIENT_KEY=your_bitbucket_oauth_consumer_key
BITBUCKET_CLIENT_SECRET=your_bitbucket_oauth_consumer_secret

# ── Cloudflare D1 (persistent profiles) ─────────────────────────────
# The DB binding is configured in wrangler.jsonc (d1_databases).
# Run `wrangler d1 migrations apply gitall --local` to initialise the
# local SQLite file under .wrangler/state/v3/d1/ before using cf:preview.

